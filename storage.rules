rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isSizeValid() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB max
    }
    
    // User Profile Photos
    match /users/{userId}/profile/{fileName} {
      allow read: if true; // Public profile photos
      allow write: if isAuthenticated() 
                   && isOwner(userId)
                   && isImage()
                   && isSizeValid();
    }
    
    // Food Photos (for AI recognition)
    match /users/{userId}/food_photos/{fileName} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() 
                   && isOwner(userId)
                   && isImage()
                   && isSizeValid();
    }
    
    // Social Feed Photos (public)
    match /social/feed/{userId}/{fileName} {
      allow read: if true; // Public feed
      allow write: if isAuthenticated() 
                   && isOwner(userId)
                   && isImage()
                   && isSizeValid();
    }
    
    // Default: Deny everything
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}